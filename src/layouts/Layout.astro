---
import "../styles/global.css";
import type { Project } from "../data/projects";

interface Props {
  title?: string;
  description?: string;
  project?: Project;
}

const { title = "Tools", description, project } = Astro.props;

const siteUrl = "https://luisfosg.github.io/tools";
const pageUrl = new URL(Astro.url.pathname, "https://luisfosg.github.io").href;
const canonicalUrl = pageUrl.replace(/\/$/, ""); // strip trailing slash

const defaultDescription =
  "Colección de herramientas online gratuitas: calculadora de notas, generador de QR, conversor de timestamps, IBAN generator, hashes, códigos de barras y más.";
const metaDescription = description ?? project?.description ?? defaultDescription;
const fullTitle = title.endsWith("Tools") || title.includes("—") ? title : `${title} — Tools`;
const isLanding = Astro.url.pathname === "/tools/" || Astro.url.pathname === "/tools";
const ogImage = isLanding ? `${siteUrl}/screenshot.jpg` : `${siteUrl}/og-default.svg`;

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: fullTitle,
  description: metaDescription,
  url: canonicalUrl,
  inLanguage: "es",
  isPartOf: {
    "@type": "WebSite",
    name: "Tools",
    url: siteUrl,
  },
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/tools/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={Astro.url.pathname === "/tools/" ? "website" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Tools" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- hreflang -->
    <link rel="alternate" hrefLang="es" href={canonicalUrl} />
    <link rel="alternate" hrefLang="x-default" href={canonicalUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={structuredData}></script>

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("dark");
        if (stored === null) {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } else if (stored === "true") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <slot />

    <!-- Dark mode toggle -->
    <button
      id="dark-toggle"
      class="fixed bottom-4 left-4 z-50 flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-lg ring-1 ring-gray-200 transition-all hover:scale-110 hover:shadow-xl dark:bg-gray-800 dark:ring-gray-700"
      aria-label="Toggle dark mode"
    >
      <!-- Sun (shown in dark mode) -->
      <svg id="dark-icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="hidden h-5 w-5 text-yellow-400 dark:block">
        <path d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6zM15.657 5.404a.75.75 0 10-1.06-1.06l-1.061 1.06a.75.75 0 001.06 1.06l1.06-1.06zM6.464 14.596a.75.75 0 10-1.06-1.06l-1.06 1.06a.75.75 0 001.06 1.06l1.06-1.06zM18 10a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5h1.5A.75.75 0 0118 10zM5 10a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5h1.5A.75.75 0 015 10zM14.596 15.657a.75.75 0 001.06-1.06l-1.06-1.06a.75.75 0 10-1.06 1.06l1.06 1.06zM5.404 6.464a.75.75 0 001.06-1.06l-1.06-1.06a.75.75 0 10-1.06 1.06l1.06 1.06z" />
      </svg>
      <!-- Moon (shown in light mode) -->
      <svg id="dark-icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-indigo-600 dark:hidden">
        <path fillRule="evenodd" d="M7.455 2.004a.75.75 0 01.26.77 7 7 0 009.958 7.967.75.75 0 011.067.853A8.5 8.5 0 116.647 1.921a.75.75 0 01.808.083z" clipRule="evenodd" />
      </svg>
    </button>
  </body>
</html>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.getElementById("dark-toggle").addEventListener("click", function () {
      const html = document.documentElement;
      const isDark = html.classList.toggle("dark");
      localStorage.setItem("dark", String(isDark));
    });
  });
</script>
