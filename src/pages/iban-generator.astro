---
import Layout from "../layouts/Layout.astro";
import IbanGenerator from "../components/IbanGenerator";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "iban-generator");
---

<Layout
  title={`${project?.title ?? "IBAN Generator"} — Tools`}
  description="Generá IBANs de prueba válidos para la UE con BIC, banco y cuenta consistentes. Ideal para testing de sistemas de pago."
  project={project}
>
  <h1 class="sr-only">IBAN Generator — Generador de IBANs de prueba</h1>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <IbanGenerator client:load />
</Layout>
