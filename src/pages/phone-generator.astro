---
import Layout from "../layouts/Layout.astro";
import PhoneGenerator from "../components/PhoneGenerator";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "phone-generator");
---

<Layout title={`${project?.title ?? "Phone Generator"} — Tools`}>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <PhoneGenerator client:load />
</Layout>
