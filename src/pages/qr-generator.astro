---
import Layout from "../layouts/Layout.astro";
import QrGenerator from "../components/react/QrGenerator";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "qr-generator");
---

<Layout
  title={`${project?.title ?? "QR Generator"} — Tools`}
  description="Generá códigos QR personalizados con colores, gradientes, logo y estilos. Descargá en PNG, SVG o JPG."
  project={project}
>
  <h1 class="sr-only">QR Generator — Generador de códigos QR personalizados</h1>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <QrGenerator client:load />
</Layout>
