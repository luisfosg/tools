---
import Layout from "../layouts/Layout.astro";
import SeoViewer from "../components/react/SeoViewer";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "seo-viewer");
---

<Layout
  title={`${project?.title ?? "SEO Viewer"} — Tools`}
  description="Analizá el SEO de cualquier página: title, meta description, Open Graph, Twitter Cards, canonical, headings y structured data. Con puntuación y recomendaciones."
  project={project}
>
  <h1 class="sr-only">SEO Viewer — Analizador de SEO para páginas web</h1>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <SeoViewer client:load />
</Layout>
