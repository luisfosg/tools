---
import Layout from "../layouts/Layout.astro";
import TimestampTool from "../components/TimestampTool";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "timestamp");
---

<Layout
  title={`${project?.title ?? "Timestamp"} — Tools`}
  description="Convertí timestamps Unix a ISO 8601, calculá diferencias entre fechas, convertí entre zonas horarias y formateá fechas online."
  project={project}
>
  <h1 class="sr-only">Timestamp — Conversor de timestamps y zonas horarias</h1>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <TimestampTool client:load />
</Layout>
