---
import Layout from "../layouts/Layout.astro";
import BarcodeGenerator from "../components/react/BarcodeGenerator";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "barcode-generator");
---

<Layout
  title={`${project?.title ?? "Barcode Generator"} — Tools`}
  description="Generá códigos de barras en 11 formatos: CODE128, EAN-13, UPC-A, CODE39, ITF-14 y más. Descargá en PNG o SVG."
  project={project}
>
  <h1 class="sr-only">Barcode Generator — Generador de códigos de barras</h1>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <BarcodeGenerator client:load />
</Layout>
