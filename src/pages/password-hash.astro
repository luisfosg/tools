---
import Layout from "../layouts/Layout.astro";
import PasswordHash from "../components/PasswordHash";
import { projects } from "../data/projects";

const project = projects.find((p) => p.slug === "password-hash");
---

<Layout
  title={`${project?.title ?? "Password Hash"} — Tools`}
  description="Generá hashes bcrypt, SHA-256, SHA-512, HMAC, PBKDF2 y JWT online. Configurá salt rounds y secretos."
  project={project}
>
  <h1 class="sr-only">Password Hash — Generador de hashes y JWT</h1>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <a
      href="/tools/"
      class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300"
    >
      <span class="text-lg leading-none">←</span>
      Tools
    </a>
  </div>
  <PasswordHash client:load />
</Layout>
