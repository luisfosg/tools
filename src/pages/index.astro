---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";
---

<Layout title="Noteffy — Project Hub">
  <main class="mx-auto min-h-screen max-w-5xl px-4 py-12">
    <!-- Hero -->
    <header class="mb-16 text-center">
      <h1 class="text-6xl font-extrabold tracking-tight text-indigo-600">
        Noteffy
      </h1>
      <p class="mt-3 text-lg text-gray-500">
        Colección de herramientas y proyectos
      </p>
    </header>

    <!-- Project Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <a
          href={`/noteffy/projects/${p.slug}`}
          class="group relative overflow-hidden rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-100 transition-all hover:-translate-y-1 hover:shadow-xl hover:ring-indigo-200"
        >
          <!-- Status badge -->
          <span
            class={`absolute right-3 top-3 rounded-full px-2.5 py-0.5 text-xs font-semibold ${
              p.status === "active"
                ? "bg-green-100 text-green-700"
                : p.status === "wip"
                  ? "bg-yellow-100 text-yellow-700"
                  : "bg-gray-100 text-gray-500"
            }`}
          >
            {p.status === "active"
              ? "Activo"
              : p.status === "wip"
                ? "En desarrollo"
                : "Planeado"}
          </span>

          <!-- Icon -->
          <div class="mb-4 text-4xl">{p.icon}</div>

          <!-- Title -->
          <h2 class="text-xl font-bold text-gray-800 group-hover:text-indigo-600">
            {p.title}
          </h2>

          <!-- Description -->
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            {p.description}
          </p>

          <!-- Arrow -->
          <div class="mt-4 flex items-center gap-1 text-sm font-medium text-indigo-600 opacity-0 transition-opacity group-hover:opacity-100">
            Abrir
            <span class="text-lg leading-none">→</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Footer -->
    <footer class="mt-20 text-center text-xs text-gray-400">
      <p>&copy; {new Date().getFullYear()} Noteffy</p>
    </footer>
  </main>
</Layout>
